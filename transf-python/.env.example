# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM=ishua:task:stream
REDIS_GROUP=ishua-ai-workers
REDIS_CONSUMER=worker_node_1

# MinerU
MINERU_TOKEN=
MINERU_BASE_URL=https://mineru.net/api/v4

# LLM
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Debug：开启后每个任务在 DEBUG_TEMP_DIR 下创建独立目录，保存 MinerU zip、markdown、LLM user prompt 与原始返回
DEBUG_MODE=false
DEBUG_TEMP_DIR=./temp

# 跳过 LLM：仅跑 MinerU 解析，结果为空题目列表（调试 MinerU 时可用，无需配置 LLM_API_KEY）
SKIP_LLM=false
